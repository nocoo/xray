{
  "name": "x-ray",
  "version": "1.9.9",
  "description": "Twitter tech content monitoring system",
  "type": "module",
  "scripts": {
    "dev": "vinext dev --port 7007",
    "build": "vinext build",
    "start": "vinext start --port 7007",
    "lint": "eslint --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:api": "bun run scripts/run-e2e-api.ts",
    "test:e2e:browser": "npx playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "release": "bun run scripts/release.ts",
    "watchlist": "bun run scripts/manage-watchlist.ts",
    "xray-me": "bun run scripts/run-me-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.1",
    "@ai-sdk/openai": "4.0.2",
    "@radix-ui/react-collapsible": "^1.1.14",
    "ai": "7.0.4",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "ip-address": "^10.2.0",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vinext": "^0.1.8"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "overrides": {
    "@vitejs/plugin-rsc": ">=0.5.26",
    "esbuild": ">=0.28.1",
    "fast-uri": ">=3.1.2",
    "hono": ">=4.12.27",
    "ip-address": ">=10.1.1",
    "next": ">=16.2.9",
    "postcss": ">=8.5.10",
    "qs": ">=6.15.2",
    "react-server-dom-webpack": ">=19.2.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  }
}
