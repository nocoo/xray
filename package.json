{
  "name": "x-ray",
  "version": "1.9.1",
  "description": "Twitter tech content monitoring system",
  "type": "module",
  "scripts": {
    "dev": "vinext dev --port 7027",
    "build": "vinext build",
    "start": "vinext start --port 7027",
    "lint": "eslint",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e:browser": "npx playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "release": "bun run scripts/release.ts",
    "watchlist": "bun run scripts/manage-watchlist.ts",
    "xray-me": "bun run scripts/run-me-report.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vinext": "^0.0.21"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ]
}
